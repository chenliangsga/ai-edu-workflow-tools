# ---------------------------------------------------------------------------
# AI Edu Workflow Tools — environment configuration
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ---------------------------------------------------------------------------

# HTTP server
PORT=4173
NODE_ENV=development

# ---------------------------------------------------------------------------
# AI model (OpenAI-compatible Chat Completions API)
# Works with the OpenAI API or any OpenAI-compatible gateway.
# ---------------------------------------------------------------------------
AI_PROVIDER=openai
# Base URL of the OpenAI-compatible endpoint. `/chat/completions` is appended
# automatically if missing.
AI_ENDPOINT=https://api.openai.com/v1
AI_API_KEY=your_api_key_here
# Text model used for grading, explanations and outlines.
AI_MODEL=gpt-4o-mini
# Vision model used to read photos of homework / essays.
AI_VISION_MODEL=gpt-4o-mini
# Send `enable_thinking` to the model. Set to "false" to disable.
AI_ENABLE_THINKING=false
AI_TIMEOUT_MS=25000

# Standard OpenAI variables are also honoured as fallbacks:
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=

# Optional: DeepSeek as an alternative text model.
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# MySQL (optional)
# Without MYSQL_PASSWORD the app falls back to local data/*.jsonl files,
# so you can run it with zero database setup.
# ---------------------------------------------------------------------------
MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_edu
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_TABLE_PREFIX=edu_

# ---------------------------------------------------------------------------
# Email verification-code login (optional)
# Use your mail provider's SMTP authorization code as SMTP_PASS.
# When SMTP is not configured, set AUTH_EXPOSE_DEV_CODE=true to receive the
# login code directly in the API response for local testing.
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_mailbox@example.com
SMTP_PASS=your_smtp_authorization_code
MAIL_FROM="AI Edu Workflow Tools <your_mailbox@example.com>"
MAIL_APP_NAME=AI Edu Workflow Tools
AUTH_EXPOSE_DEV_CODE=true
